{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "aaronfrancis/fast-paginate": "^2.0",
        "akaunting/laravel-apexcharts": "^3.0",
        "andrewdwallo/filament-selectify": "^3.0",
        "awcodes/filament-badgeable-column": "^3.0",
        "awcodes/filament-curator": "^4.0",
        "awcodes/shout": "^3.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "bezhansalleh/filament-shield": "^4.0",
        "charrafimed/global-search-modal": "^4.0",
        "cheesegrits/filament-google-maps": "^4.0",
        "coolsam/flatpickr": "^5.0",
        "croustibat/filament-jobs-monitor": "^4.4",
        "filament/filament": "^4.0",
        "guzzlehttp/guzzle": "^7.8",
        "jeffgreco13/filament-breezy": "^3.0",
        "kenepa/banner": "^1.0",
        "laravel/framework": "^12.0",
        "laravel/octane": "^2.17",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "leandrocfe/filament-apex-charts": "^5.0",
        "malzariey/filament-daterangepicker-filter": "^5.0",
        "njxqlus/filament-progressbar": "^2.0",
        "outerweb/filament-settings": "*",
        "psr/simple-cache": "^3.0",
        "pxlrbt/filament-activity-log": "^3.1",
        "pxlrbt/filament-excel": "^3.6",
        "pxlrbt/filament-spotlight": "^2.0",
        "spatie/laravel-activitylog": "^5.0",
        "spykapps/theme-edinburgh": "^1.0",
        "staudenmeir/eloquent-has-many-deep": "^1.20",
        "vodafoneziggonl/filament-multi-widget": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0",
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app\\helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan filament:upgrade"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "cacheapp": [
            "@php artisan optimize",
            "@php artisan icons:cache",
            "@php artisan filament:cache-components"
        ],
        "clearcache": [
            "@php artisan optimize:clear",
            "@php artisan filament:clear-cached-components"
        ],
        "clearjobs": [
            "@php artisan queue:flush",
            "@php artisan queue:clear",
            "@php artisan queue:prune-batches",
            "@php artisan queue:prune-failed"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "platform-check": false,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
